{
  "name": "eleventy-blog",
  "version": "1.0.0",
  "type": "module",
  "description": "Stunning Eleventy blog with TypeScript and Tailwind",
  "scripts": {
    "start": "concurrently \"npm run tw:watch\" \"npm run ts:watch\" \"npm run 11ty:serve\"",
    "build": "npm run tw:build && npm run ts:build && npm run 11ty:build",
    "11ty:serve": "eleventy --serve --port=8080",
    "11ty:build": "eleventy",
    "tw:watch": "tailwindcss -i ./src/assets/css/main.css -o ./src/assets/css/tailwind.css --watch",
    "tw:build": "tailwindcss -i ./src/assets/css/main.css -o ./src/assets/css/tailwind.css --minify",
    "ts:watch": "tsc --watch",
    "ts:build": "tsc"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "@11ty/eleventy-plugin-rss": "^2.0.2",
    "@11ty/eleventy-plugin-syntaxhighlight": "^5.0.0",
    "concurrently": "^9.0.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "@tailwindcss/typography": "^0.5.19"
  }
}

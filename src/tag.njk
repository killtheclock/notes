---
layout: layouts/base.njk
pagination:
  data: collections.tagList
  size: 1
  alias: tag
permalink: /tags/{{ tag | slugify }}/
---
{% set tagPosts = collections.posts | filterByTag(tag) %}

<section class="max-w-5xl mx-auto px-6 py-16">
  <a href="/tags/" class="inline-flex items-center gap-2 text-sm text-ghost-500 hover:text-aurora-violet transition-colors mb-10 group">
    <svg class="w-4 h-4 group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 17l-5-5m0 0l5-5m-5 5h12"/>
    </svg>
    Όλα τα θέματα
  </a>

  <div class="mb-12">
    <p class="font-mono text-xs text-aurora-violet tracking-widest mb-3">— ΘΕΜΑ</p>
    <h1 class="font-display font-800 text-5xl text-ghost-100 mb-4 capitalize">{{ tag }}</h1>
    <p class="text-ghost-400">{{ tagPosts | length }} άρθρα με αυτό το θέμα</p>
  </div>

  <div class="space-y-5">
    {% for post in tagPosts %}
    <a href="{{ post.url }}" class="glass-card block p-6 group animate-on-scroll">
      <div class="flex flex-wrap items-center gap-2 mb-3">
        {% if post.data.category %}
        <span class="tag-pill badge-{{ post.data.category }} text-xs">{{ post.data.category }}</span>
        {% endif %}
        <time class="ml-auto font-mono text-xs text-ghost-500">{{ post.date | readableDate }}</time>
      </div>
      <h2 class="font-display font-700 text-xl text-ghost-100 mb-2 group-hover:text-aurora-blue transition-colors">
        {{ post.data.title }}
      </h2>
      {% if post.data.description %}
      <p class="text-sm text-ghost-400 leading-relaxed">{{ post.data.description }}</p>
      {% endif %}
    </a>
    {% endfor %}
  </div>
</section>

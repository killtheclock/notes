---
layout: layouts/base.njk
title: Θέματα
description: Όλα τα θέματα του blog
permalink: /tags/
---

<section class="max-w-5xl mx-auto px-6 py-16">
  <div class="mb-16">
    <p class="font-mono text-xs text-aurora-violet tracking-widest mb-3">— ΚΑΤΗΓΟΡΙΕΣ</p>
    <h1 class="font-display font-800 text-5xl text-ghost-100 mb-4">Θέματα</h1>
    <p class="text-ghost-400 text-lg">{{ collections.tagList | length }} κατηγορίες συνολικά</p>
  </div>

  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
    {% for tag in collections.tagList %}
    {% set tagPosts = collections.posts | filterByTag(tag) %}
    <a href="/notes/tags/{{ tag | slugify }}/" class="glass-card p-6 group animate-on-scroll">
      <div class="flex items-start justify-between mb-4">
        <div class="w-10 h-10 rounded-xl bg-aurora-blue/10 border border-aurora-blue/20 flex items-center justify-center
                    group-hover:bg-aurora-blue/20 transition-colors">
          <span class="font-mono text-sm text-aurora-blue font-medium">#</span>
        </div>
        <span class="font-mono text-xs text-ghost-500">{{ tagPosts | length }} άρθρα</span>
      </div>
      <h2 class="font-display font-600 text-lg text-ghost-100 group-hover:text-aurora-blue transition-colors capitalize">
        {{ tag }}
      </h2>
      {% if tagPosts[0] %}
      <p class="text-xs text-ghost-500 mt-2 line-clamp-1">Τελευταίο: {{ tagPosts[0].data.title }}</p>
      {% endif %}
    </a>
    {% endfor %}
  </div>
</section>

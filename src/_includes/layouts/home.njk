---
layout: layouts/base.njk
---
{% set allPosts = collections.posts %}
{% set featuredPosts = allPosts | limit(3) %}
{% set tagList = collections.tagList %}

<!-- ── HERO ── -->
<section class="relative min-h-[80vh] flex flex-col items-center justify-center px-6 py-24 text-center overflow-hidden">

  <!-- Floating orbs -->
  <div class="absolute top-1/4 left-1/4 w-64 h-64 rounded-full bg-aurora-blue/5 blur-3xl animate-float pointer-events-none"></div>
  <div class="absolute bottom-1/4 right-1/4 w-80 h-80 rounded-full bg-aurora-violet/5 blur-3xl animate-float pointer-events-none" style="animation-delay:2s"></div>

  <div class="relative z-10 max-w-3xl mx-auto">
    <!-- Eyebrow -->
    <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-aurora-blue/20 bg-aurora-blue/10 mb-8
                opacity-0 animate-fade-up stagger-1">
      <span class="w-1.5 h-1.5 rounded-full bg-aurora-teal animate-glow-pulse"></span>
      <span class="font-mono text-xs text-aurora-blue tracking-wider">BLOG / ΓΝΩΣΗ / ΙΔΕΕΣ</span>
    </div>

    <h1 class="font-display font-800 text-5xl md:text-7xl leading-[1.05] tracking-tight mb-6
               opacity-0 animate-fade-up stagger-2">
      Σκέψεις που<br>
      <span class="gradient-text">αφήνουν σημάδι</span>
    </h1>

    <p class="text-ghost-400 text-lg md:text-xl leading-relaxed mb-10 max-w-xl mx-auto
              opacity-0 animate-fade-up stagger-3">
      Άρθρα για τεχνολογία, design, code και ό,τι άλλο αξίζει να σκεφτεί κανείς.
      Γραμμένα με προσοχή. Διαβασμένα με γούστο.
    </p>

    <div class="flex flex-wrap items-center justify-center gap-4 opacity-0 animate-fade-up stagger-4">
      <a href="/notes/blog/" class="btn-glow">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
        </svg>
        Όλα τα άρθρα
      </a>
      <a href="/notes/tags/" class="inline-flex items-center gap-2 px-6 py-2.5 rounded-xl font-display font-medium text-sm
                              text-ghost-300 border border-white/10 hover:border-white/16 hover:text-ghost-100 transition-all">
        Περιήγηση θεμάτων
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-ghost-500 opacity-0 animate-fade-up stagger-5">
    <span class="font-mono text-xs tracking-widest">SCROLL</span>
    <div class="w-px h-12 bg-gradient-to-b from-ghost-500/50 to-transparent"></div>
  </div>
</section>

<!-- ── STATS BAR ── -->
<section class="max-w-5xl mx-auto px-6 mb-20 opacity-0 animate-fade-up stagger-3">
  <div class="grid grid-cols-3 gap-px rounded-2xl overflow-hidden border border-white/5">
    <div class="bg-night-800/40 backdrop-blur-sm px-8 py-6 text-center">
      <p class="font-display font-700 text-3xl text-ghost-100">{{ allPosts | length }}</p>
      <p class="text-sm text-ghost-500 mt-1">Άρθρα</p>
    </div>
    <div class="bg-night-800/40 backdrop-blur-sm px-8 py-6 text-center border-x border-white/5">
      <p class="font-display font-700 text-3xl text-ghost-100">{{ tagList | length }}</p>
      <p class="text-sm text-ghost-500 mt-1">Θέματα</p>
    </div>
    <div class="bg-night-800/40 backdrop-blur-sm px-8 py-6 text-center">
      <p class="font-display font-700 text-3xl gradient-text">∞</p>
      <p class="text-sm text-ghost-500 mt-1">Ιδέες</p>
    </div>
  </div>
</section>

<!-- ── FEATURED POSTS ── -->
<section class="max-w-5xl mx-auto px-6 mb-20">
  <div class="flex items-center justify-between mb-10">
    <div>
      <p class="font-mono text-xs text-aurora-blue tracking-widest mb-2">— ΤΕΛΕΥΤΑΙΑ ΑΡΘΡΑ</p>
      <h2 class="font-display font-700 text-3xl text-ghost-100">Πρόσφατες δημοσιεύσεις</h2>
    </div>
    <a href="/notes/blog/" class="hidden md:flex items-center gap-2 text-sm text-ghost-400 hover:text-aurora-blue transition-colors">
      Δείτε όλα
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
      </svg>
    </a>
  </div>

  <!-- Featured first post (large) -->
  {% if featuredPosts[0] %}
  {% set post = featuredPosts[0] %}
  <a href="/notes{{ post.url }}" class="glass-card block p-8 mb-5 group animate-on-scroll">
    <div class="flex flex-wrap items-center gap-3 mb-5">
      {% if post.data.category %}
      <span class="tag-pill badge-{{ post.data.category }}">{{ post.data.category }}</span>
      {% endif %}
      {% if post.data.tags %}
        {% for tag in post.data.tags %}
          {% if tag != "posts" %}
          <span class="tag-pill">{{ tag }}</span>
          {% endif %}
        {% endfor %}
      {% endif %}
      <span class="ml-auto font-mono text-xs text-ghost-500">{{ post.date | readableDate }}</span>
    </div>
    <h3 class="font-display font-700 text-2xl md:text-3xl text-ghost-100 mb-3 group-hover:text-aurora-blue transition-colors">
      {{ post.data.title }}
    </h3>
    {% if post.data.description %}
    <p class="text-ghost-400 leading-relaxed mb-5">{{ post.data.description }}</p>
    {% endif %}
    <div class="flex items-center gap-2 text-sm text-aurora-blue">
      Διαβάστε περισσότερα
      <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
      </svg>
    </div>
  </a>
  {% endif %}

  <!-- Remaining 2 posts (grid) -->
  <div class="grid md:grid-cols-2 gap-5">
    {% for post in featuredPosts %}
    {% if loop.index > 1 %}
    <a href="/notes{{ post.url }}" class="glass-card block p-6 group animate-on-scroll">
      <div class="flex flex-wrap items-center gap-2 mb-4">
        {% if post.data.category %}
        <span class="tag-pill badge-{{ post.data.category }} text-xs">{{ post.data.category }}</span>
        {% endif %}
        <span class="ml-auto font-mono text-xs text-ghost-500">{{ post.date | readableDate }}</span>
      </div>
      <h3 class="font-display font-600 text-xl text-ghost-100 mb-2 group-hover:text-aurora-blue transition-colors">
        {{ post.data.title }}
      </h3>
      {% if post.data.description %}
      <p class="text-sm text-ghost-400 leading-relaxed line-clamp-2">{{ post.data.description }}</p>
      {% endif %}
    </a>
    {% endif %}
    {% endfor %}
  </div>
</section>

<!-- ── TAG CLOUD ── -->
<section class="max-w-5xl mx-auto px-6 mb-20 animate-on-scroll">
  <div class="glass-card p-8">
    <p class="font-mono text-xs text-aurora-violet tracking-widest mb-2">— ΘΕΜΑΤΑ</p>
    <h2 class="font-display font-700 text-2xl text-ghost-100 mb-6">Περιηγηθείτε ανά κατηγορία</h2>
    <div class="flex flex-wrap gap-2.5">
      {% for tag in tagList %}
      {% set tagPosts = collections.posts | filterByTag(tag) %}
      <a href="/tags/{{ tag | slugify }}/" class="tag-pill hover:badge-tech">
        {{ tag }}
        <span class="ml-1.5 text-ghost-500">{{ tagPosts | length }}</span>
      </a>
      {% endfor %}
    </div>
  </div>
</section>

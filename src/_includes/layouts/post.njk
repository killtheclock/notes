---
layout: layouts/base.njk
---
{% set readingTime = content | wordcount / 200 | round %}

<article class="max-w-5xl mx-auto px-6 py-12">

  <!-- Back link -->
  <a href="/notes/blog/" class="inline-flex items-center gap-2 text-sm text-ghost-500 hover:text-aurora-blue transition-colors mb-10 group">
    <svg class="w-4 h-4 group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 17l-5-5m0 0l5-5m-5 5h12"/>
    </svg>
    Όλα τα άρθρα
  </a>

  <div class="grid grid-cols-1 lg:grid-cols-[1fr_280px] gap-12">

    <!-- ── MAIN CONTENT ── -->
    <div>
      <!-- Post header -->
      <header class="mb-12">
        <!-- Tags -->
        <div class="flex flex-wrap items-center gap-2.5 mb-6">
          {% if category %}
          <span class="tag-pill badge-{{ category }}">{{ category }}</span>
          {% endif %}
          {% if tags %}
            {% for tag in tags %}
              {% if tag != "posts" %}
              <a href="/tags/{{ tag | slugify }}/" class="tag-pill hover:border-aurora-blue/30 hover:text-aurora-blue">
                {{ tag }}
              </a>
              {% endif %}
            {% endfor %}
          {% endif %}
        </div>

        <h1 class="font-display font-800 text-4xl md:text-5xl text-ghost-100 leading-[1.1] tracking-tight mb-6">
          {{ title }}
        </h1>

        {% if description %}
        <p class="text-xl text-ghost-400 leading-relaxed mb-8">{{ description }}</p>
        {% endif %}

        <!-- Meta row -->
        <div class="flex flex-wrap items-center gap-5 text-sm text-ghost-500 pb-8 border-b border-white/5">
          {% if author %}
          <span class="flex items-center gap-2">
            <div class="w-6 h-6 rounded-full bg-aurora-blue/20 flex items-center justify-center text-xs text-aurora-blue">
              {{ author[0] | upper }}
            </div>
            {{ author }}
          </span>
          {% endif %}
          <span class="flex items-center gap-1.5">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
            <time datetime="{{ page.date | htmlDateString }}">{{ page.date | readableDate }}</time>
          </span>
          <span class="flex items-center gap-1.5">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            ~{{ readingTime }} λεπτά ανάγνωση
          </span>
        </div>
      </header>

      <!-- Post body -->
      <div class="post-content prose prose-invert max-w-none" id="post-body">
        {{ content | safe }}
      </div>

      <!-- Share section -->
      <div class="mt-16 pt-8 border-t border-white/5">
        <p class="font-display text-sm text-ghost-400 mb-4">Μοιραστείτε το άρθρο</p>
        <div class="flex gap-3">
          <a href="https://twitter.com/intent/tweet?text={{ title | urlencode }}&url={{ page.url | absoluteUrl(site.url) | urlencode }}"
             target="_blank" rel="noopener"
             class="tag-pill hover:border-[#1DA1F2]/30 hover:text-[#1DA1F2]">
            Twitter / X
          </a>
          <button onclick="navigator.clipboard.writeText(window.location.href); this.textContent='Αντιγράφηκε!'; setTimeout(()=>this.textContent='Αντιγραφή link',2000)"
                  class="tag-pill cursor-pointer">
            Αντιγραφή link
          </button>
        </div>
      </div>
    </div>

    <!-- ── SIDEBAR ── -->
    <aside class="hidden lg:block">
      <div class="sticky top-28 space-y-6">

        <!-- Table of contents (auto-generated by JS) -->
        <div class="glass-card p-6" id="toc-container" style="display:none">
          <p class="font-mono text-xs text-aurora-blue tracking-widest mb-4">— ΠΕΡΙΕΧΟΜΕΝΑ</p>
          <nav id="toc" class="space-y-1"></nav>
        </div>

        <!-- Post meta card -->
        <div class="glass-card p-6">
          <p class="font-mono text-xs text-aurora-violet tracking-widest mb-4">— ΛΕΠΤΟΜΕΡΕΙΕΣ</p>
          <dl class="space-y-3 text-sm">
            <div>
              <dt class="text-ghost-500 mb-0.5">Ημερομηνία</dt>
              <dd class="text-ghost-200">{{ page.date | readableDate }}</dd>
            </div>
            {% if category %}
            <div>
              <dt class="text-ghost-500 mb-0.5">Κατηγορία</dt>
              <dd><span class="tag-pill badge-{{ category }}">{{ category }}</span></dd>
            </div>
            {% endif %}
            <div>
              <dt class="text-ghost-500 mb-0.5">Χρόνος ανάγνωσης</dt>
              <dd class="text-ghost-200">~{{ readingTime }} λεπτά</dd>
            </div>
          </dl>
        </div>

        <!-- Tags card -->
        {% if tags %}
        <div class="glass-card p-6">
          <p class="font-mono text-xs text-aurora-teal tracking-widest mb-4">— TAGS</p>
          <div class="flex flex-wrap gap-2">
            {% for tag in tags %}
              {% if tag != "posts" %}
              <a href="/tags/{{ tag | slugify }}/" class="tag-pill text-xs">{{ tag }}</a>
              {% endif %}
            {% endfor %}
          </div>
        </div>
        {% endif %}

      </div>
    </aside>
  </div>
</article>

<script>
  // Reading progress bar
  const bar = document.getElementById('reading-progress');
  const body = document.getElementById('post-body');
  if (bar && body) {
    window.addEventListener('scroll', () => {
      const bodyTop = body.offsetTop;
      const bodyH   = body.offsetHeight;
      const scrolled = window.scrollY - bodyTop;
      const pct = Math.min(100, Math.max(0, (scrolled / bodyH) * 100));
      bar.style.width = pct + '%';
    });
  }

  // Auto-generate TOC from headings
  const tocContainer = document.getElementById('toc-container');
  const toc          = document.getElementById('toc');
  const headings = document.querySelectorAll('.post-content h2, .post-content h3');

  if (headings.length > 1 && toc && tocContainer) {
    tocContainer.style.display = 'block';
    headings.forEach((h, i) => {
      if (!h.id) h.id = 'heading-' + i;
      const a = document.createElement('a');
      a.href = '#' + h.id;
      a.textContent = h.textContent;
      a.className = h.tagName === 'H2'
        ? 'block text-sm text-ghost-400 hover:text-aurora-blue transition-colors py-0.5'
        : 'block text-xs text-ghost-500 hover:text-aurora-blue transition-colors py-0.5 pl-3 border-l border-white/10';
      toc.appendChild(a);
    });

    // Active TOC item on scroll
    const observer = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          toc.querySelectorAll('a').forEach(a => a.classList.remove('text-aurora-blue'));
          const active = toc.querySelector(`a[href="#${e.target.id}"]`);
          if (active) active.classList.add('text-aurora-blue');
        }
      });
    }, { rootMargin: '-20% 0% -60% 0%' });
    headings.forEach(h => observer.observe(h));
  }
</script>

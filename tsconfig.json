{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "outDir": "./src/assets/js",
    "rootDir": "./src/ts",
    "declaration": false,
    "sourceMap": false,
    "lib": ["ES2022", "DOM"]
  },
  "include": ["src/ts/**/*", "eleventy.config.ts"],
  "exclude": ["node_modules", "_site"]
}
